# =============================================================================
# Galera Orchestrator v2 — .gitignore
# =============================================================================

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
pip-log.txt
pip-delete-this-directory.txt

# Virtual environments
.venv/
venv/
env/
ENV/

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/

# pytest / coverage
.pytest_cache/
.coverage
htmlcov/
.tox/

# mypy / pyright
.mypy_cache/
.pyright/
pyrightconfig.json

# ── Node / Frontend ───────────────────────────────────────────────────────────
node_modules/
frontend/node_modules/

# Vite build output — lives in backend/static/ after `npm run build`
# Never commit built frontend — it's regenerated by Dockerfile Stage 1
backend/static/

# Cookie Files (curl/httpie session artifacts — never commit)
cookie.txt
backend/cookie.txt
*.cookiejar

# Vite cache
frontend/.vite/
frontend/dist/

# npm / yarn logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Docker ────────────────────────────────────────────────────────────────────
# Don't ignore docker-compose.yml itself, but ignore overrides with secrets
docker-compose.override.yml
docker-compose.local.yml

# ── Environment / Secrets ─────────────────────────────────────────────────────
# .env contains real secrets — NEVER commit
.env

# .env.example is committed (contains placeholder values, no real secrets)
# !.env.example  ← already tracked, no need for explicit negation

# ── SQLite (local dev only) ───────────────────────────────────────────────────
*.db
*.db-shm
*.db-wal
# But not the /data/ directory structure — it's created by Docker

# ── SSH keys ──────────────────────────────────────────────────────────────────
# Per ТЗ раздел 3.2: SSH key is bind-mounted, never stored in repo
*.pem
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub
.ssh/

# ── OS / Editor ───────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
Desktop.ini

.idea/
.vscode/
*.swp
*.swo
*~

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/
