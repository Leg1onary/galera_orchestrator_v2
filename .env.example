# Galera Orchestrator v2 — Environment Variables
# Копируй в корень проекта: cp .env.example .env
# Заполни реальными значениями перед запуском

# ── Expose ───────────────────────────────────────────────────────────────
HOST_PORT=8000

# ── Auth ────────────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# JWT: минимум 32 символа, случайная строка
# openssl rand -hex 32
JWT_SECRET_KEY=change-me-jwt-secret-min-32-chars

# ── Encryption ──────────────────────────────────────────────────────────
FERNET_SECRET_KEY=change-me-fernet-key

# ── Database ────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:////data/orchestrator.db
DB_CONNECT_TIMEOUT=3

# ── SSH ────────────────────────────────────────────────────────────────
# Путь к приватному SSH-ключу
# Docker: /root/.ssh/id_rsa  (монтируется read-only через volumes)
# Локально: укажи полный путь, например: /home/user/.ssh/id_rsa
SSH_KEY_PATH=/root/.ssh/id_rsa
SSH_CONNECT_TIMEOUT=5
SSH_COMMAND_TIMEOUT=10
