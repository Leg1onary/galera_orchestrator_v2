# Galera Orchestrator v2 — Environment Variables
# cp .env.example .env  →  заполни реальными значениями

# ── Expose ──────────────────────────────────────────────────────────────────
HOST_PORT=8000

# ── Auth ────────────────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# JWT: минимум 32 символа, случайная строка
# openssl rand -hex 32
JWT_SECRET_KEY=change-me-jwt-secret-min-32-chars

# ── Encryption ───────────────────────────────────────────────────────────────
# Fernet key для шифрования паролей нод в SQLite
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_SECRET_KEY=change-me-fernet-key

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:////data/orchestrator.db

# ── SSH ──────────────────────────────────────────────────────────────────────
# Путь на ХОСТЕ к приватному ключу (монтируется read-only в контейнер)
SSH_KEY_HOST_PATH=~/.ssh/id_rsa

# Таймауты (секунды)
SSH_CONNECT_TIMEOUT=5
SSH_COMMAND_TIMEOUT=10
DB_CONNECT_TIMEOUT=3