# Galera Orchestrator v2 — Environment Variables
# Копируй в корень проекта: cp .env.example .env
# Заполни реальными значениями перед запуском
#
# ОБЯЗАТЕЛЬНО изменить перед первым запуском:
#   ADMIN_PASSWORD_HASH, JWT_SECRET_KEY, FERNET_SECRET_KEY

# ── Expose ───────────────────────────────────────────────────────────────
HOST_PORT=8000

# ── Auth ────────────────────────────────────────────────────────────────
ADMIN_USERNAME=admin

# Bcrypt-хеш пароля администратора (НЕ сам пароль в открытом виде)
# Генерация: python -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt()).decode())"
ADMIN_PASSWORD_HASH=                           # ← СГЕНЕРИРОВАТЬ И ВСТАВИТЬ

# JWT: минимум 32 символа, случайная строка
# Генерация: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=                                # ← СГЕНЕРИРОВАТЬ И ВСТАВИТЬ

# ── Cookie ──────────────────────────────────────────────────────────────
# true  — обязательно в проде (за HTTPS/TLS-прокси)
# false — только для локальной разработки без TLS
COOKIE_SECURE=true

# ── Encryption ──────────────────────────────────────────────────────────
# Fernet-ключ для шифрования паролей узлов в БД
# Генерация: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ВНИМАНИЕ: JWT_SECRET_KEY и FERNET_SECRET_KEY должны быть РАЗНЫМИ значениями
FERNET_SECRET_KEY=                             # ← СГЕНЕРИРОВАТЬ И ВСТАВИТЬ

# ── Database ────────────────────────────────────────────────────────────
# НЕ МЕНЯТЬ при использовании Docker
DATABASE_URL=sqlite:////data/orchestrator.db
DB_CONNECT_TIMEOUT=3

# ── SSH ─────────────────────────────────────────────────────────────────
# Путь к приватному SSH-ключу НА ХОСТЕ (bind-mount :ro внутрь контейнера)
# Генерация нового ключа: ssh-keygen -t ed25519 -N "" -f ~/.ssh/galera_key
SSH_KEY_PATH=~/.ssh/id_rsa
SSH_CONNECT_TIMEOUT=5
SSH_COMMAND_TIMEOUT=10

# ── App ────────────────────────────────────────────────────────────────
# false (default) — /docs, /redoc, /openapi.json недоступны (прод)
# true            — включить только для локальной разработки
DOCS_ENABLED=false
