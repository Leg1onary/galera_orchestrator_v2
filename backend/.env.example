# Galera Orchestrator v2 — environment variables
# Copy to .env and fill in real values before starting.

# Admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# JWT secret — min 32 chars, unique
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-jwt-secret-min-32-chars-unique

# Fernet secret — must be a URL-safe base64-encoded 32-byte key
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_SECRET_KEY=change-me-fernet-base64-key

# SSH key path (inside container — mounted read-only)
SSH_KEY_PATH=/root/.ssh/id_rsa

# App version (informational)
APP_VERSION=2.0.0