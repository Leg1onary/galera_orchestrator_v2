# =============================================================================
# Galera Orchestrator v2 — DEV environment variables
# Used with docker-compose.dev.yml + local `uvicorn main:app` dev run.
# NEVER commit real secrets. This file is for local dev only.
# =============================================================================

# ── Database (SQLite for orchestrator itself) ─────────────────────────────────
DATABASE_URL=sqlite:///./dev-orchestrator.db

# ── Admin credentials ─────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=devpass

# ── JWT (can be any string in dev) ───────────────────────────────────────────
JWT_SECRET_KEY=dev-jwt-secret-not-for-production

# ── Fernet (generate a real key even in dev — used for db_password encryption)
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_SECRET_KEY=dev-fernet-key-replace-with-real-base64-key

# ── SSH key (path on your local machine — same key whose public part is in SSH_PUBLIC_KEY)
SSH_KEY_PATH=~/.ssh/id_rsa

# ── SSH public key content (injected into sshd container via docker-compose.dev.yml)
# Run: cat ~/.ssh/id_rsa.pub
SSH_PUBLIC_KEY=ssh-rsa AAAAB3NzaC1yc2EAAAADAQABAAAB... your-key-here

# ── Dev MariaDB / SSHD connection info (used when adding test nodes via Settings)
# sshd container is reachable at localhost:12222 (from host) or sshd:2222 (from dev network)
# mariadb container is reachable at localhost:13306 (from host) or mariadb:3306 (from dev network)
DEV_NODE_HOST=localhost
DEV_NODE_SSH_PORT=12222
DEV_NODE_DB_PORT=13306
DEV_NODE_DB_USER=root
DEV_NODE_DB_PASSWORD=testpass